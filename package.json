{
  "name": "eugent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier -w .",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "test:e2e": "playwright test",
    "rebuild:electron": "electron-rebuild -w better-sqlite3 -f",
    "rebuild:node": "pnpm rebuild better-sqlite3 --config.node-linker=hoisted",
    "postinstall": "electron-rebuild -w better-sqlite3 -f || true"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
